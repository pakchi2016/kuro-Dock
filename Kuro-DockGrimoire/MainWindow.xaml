<Window x:Class="Kuro_DockGrimoire.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grimoire" SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        Loaded="Window_Loaded" Deactivated="Window_Deactivated"
        SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <DataTemplate x:Key="SubMenuTemplate">
            <Button Style="{StaticResource KuroDockMenuButtonStyle}" Content="{Binding Name}" MouseEnter="Bookmark_MouseEnter" Click="Bookmark_Click" Opacity="0">
                <Button.RenderTransform>
                    <TranslateTransform X="{Binding InitialOffsetX}" Y="{Binding InitialOffsetY}"/>
                </Button.RenderTransform>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="SubMenuIconTemplate">
            <Button Style="{StaticResource KuroDockIconMenuButtonStyle}" Content="{Binding Name}" Click="Bookmark_Click" Opacity="0">
                <Button.RenderTransform>
                    <TranslateTransform X="{Binding InitialOffsetX}" Y="{Binding InitialOffsetY}"/>
                </Button.RenderTransform>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource KuroDockBackgroundBrush}" BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="4">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>

        <Grid x:Name="DockPanel" Margin="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="0"/>
                <ColumnDefinition Width="Auto" MinWidth="0"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{x:Null}">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource KuroDockScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <ItemsControl x:Name="SubBookmarksPanel" Background="{StaticResource KuroDockSubPanelBrush}" ItemTemplate="{StaticResource SubMenuIconTemplate}"/>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{x:Null}">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource KuroDockScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <ItemsControl x:Name="BookmarksPanel" Background="{StaticResource KuroDockPanelBrush}" ItemTemplate="{StaticResource SubMenuTemplate}"/>
            </ScrollViewer>

            <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,5,0,5">
                <ItemsControl x:Name="ItemsControl_Indexes" Padding="0,0,0,15">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}" Width="90" Height="30" Margin="0,2,0,0" HorizontalAlignment="Right" MouseEnter="IndexButton_MouseEnter" Foreground="#DDDDDD" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Background="#1AFFFFFF" BorderBrush="#44FFFFFF" BorderThickness="3,0,0,0" CornerRadius="10,0,0,10">
                                            <TextBlock x:Name="Text" Text="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0" FontWeight="SemiBold" FontSize="13"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource KuroDockAccentBrush}"/>
                                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Image Source="pack://application:,,,/Kuro-DockThrone.Core;component/Images/kuro.png" Width="96" Height="96" HorizontalAlignment="Center" IsHitTestVisible="False"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>