<UserControl x:Class="Kuro_DockFortress.Views.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E" Foreground="#D4D4D4"
             Unloaded="UserControl_Unloaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="OutputBox" IsReadOnly="True" Background="#18181A" Foreground="#CCCCCC"
                 BorderThickness="0" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                 FontFamily="Consolas" FontSize="13" Margin="0,0,0,2" Padding="5"/>

        <Grid Grid.Row="1" Background="#2D2D30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="PromptText" Text="PS >" Foreground="#F39C12" FontFamily="Consolas" FontSize="14" 
                       VerticalAlignment="Center" Margin="5,0"/>
            
            <TextBox x:Name="InputBox" Grid.Column="1" Background="Transparent" Foreground="White"
                     BorderThickness="0" FontFamily="Consolas" FontSize="14" Padding="0,5"
                     VerticalAlignment="Center" PreviewKeyDown="InputBox_PreviewKeyDown" CaretBrush="White"/>
        </Grid>
    </Grid>
</UserControl>