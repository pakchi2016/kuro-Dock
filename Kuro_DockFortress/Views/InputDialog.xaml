<Window x:Class="Kuro_DockFortress.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新規作成" Height="250" Width="400"
        Background="#1E1E1E" Foreground="#D4D4D4"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="MessageText" Text="名前を入力してください：" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <TextBox x:Name="InputTextBox" Grid.Row="1" Background="#2D2D30" Foreground="White" 
                 BorderBrush="#3E3E42" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Height="24" Background="#3E3E42" Foreground="White" BorderThickness="0" 
                    Click="OkButton_Click" IsDefault="True" Cursor="Hand"/>
            <Button Content="キャンセル" Width="80" Height="24" Margin="10,0,0,0" Background="#3E3E42" Foreground="White" BorderThickness="0" 
                    Click="CancelButton_Click" IsCancel="True" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>