<Window x:Class="Kuro_DockFortress.Views.MainWindow"
        xmlns:local="clr-namespace:Kuro_DockFortress.Views"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kuro-DockFortress" Height="600" Width="1000"
        Background="#1E1E1E" WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False" 
        Closing="Window_Closing">
    <Window.Resources>

        <Style x:Key="FortressTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="FortressTabHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Header}" Padding="5,0,10,0" VerticalAlignment="Center" 
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"/>
                <Button Content="✕" Width="16" Height="16" Background="Transparent" BorderThickness="0"
                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"
                        Click="CloseTab_Click" Tag="{Binding}" Cursor="Hand" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="FortressTabContentTemplate">
            <Grid PreviewMouseLeftButtonDown="Pane_PreviewMouseLeftButtonDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="↑" Width="30" Height="24" Background="#3E3E42" Foreground="White" BorderThickness="0" 
                            Click="UpButton_Click" Tag="{Binding}" Cursor="Hand"/>

                    <Button Grid.Column="1" Content="＋" Width="30" Height="24" Margin="5,0,0,0" Background="#3E3E42" Foreground="White" BorderThickness="0" 
                            Click="AddTab_Click" Tag="{Binding}" Cursor="Hand" ToolTip="現在の場所で新しいタブを開く"/>

                    <Button Grid.Column="2" Content="★" Width="30" Height="24" Margin="5,0,0,0" Background="#3E3E42" Foreground="#F39C12" BorderThickness="0" 
                            Click="ShowBookmarks_Click" Tag="{Binding}" Cursor="Hand" ToolTip="ブックマークを開く (右クリックで削除)"/>

                    <Button Grid.Column="3" Content="＋★" Width="35" Height="24" Margin="5,0,0,0" Background="#3E3E42" Foreground="#F39C12" BorderThickness="0" 
                            Click="AddBookmark_Click" Tag="{Binding}" Cursor="Hand" ToolTip="現在の場所をブックマークに登録"/>

                    <TextBox Grid.Column="4" Text="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}" 
                             KeyDown="PathTextBox_KeyDown" Tag="{Binding}" 
                             Margin="5,0,0,0" Background="#2D2D30" Foreground="White" 
                             BorderThickness="1" BorderBrush="#3E3E42" Padding="4,2" VerticalContentAlignment="Center"/>
                </Grid>

                <ListView Grid.Row="1" ItemsSource="{Binding Files}" 
                          Background="Transparent" Foreground="#D4D4D4" BorderThickness="0" 
                          MouseDoubleClick="ListView_MouseDoubleClick">
                    <ListView.ContextMenu>
                        <ContextMenu Background="#2D2D30" Foreground="White" Opened="ContextMenu_Opened">
                            <MenuItem Header="新規作成">
                                <MenuItem Header="フォルダ" Click="CreateFolder_Click" Background="#2D2D30" Foreground="White"/>
                                <MenuItem Header="テキスト" Click="CreateText_Click" Background="#2D2D30" Foreground="White"/>
                            </MenuItem>
                            <Separator Background="#3E3E42" Foreground="#3E3E42"/>

                            <MenuItem Header="切り取り" Click="CutItem_Click" />
                            <MenuItem Header="コピー" Click="CopyItem_Click" />
                            <MenuItem Header="貼り付け" Click="PasteItem_Click" />
                            <Separator Background="#3E3E42" Foreground="#3E3E42" />
                            <MenuItem Header="削除" Click="DeleteItem_Click" />
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Foreground" Value="#D4D4D4"/>
                            <Setter Property="Margin" Value="0,1"/>

                            <Setter Property="Background" Value="Transparent"/>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E5E5"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>

                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="名前" Width="250">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,5,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="更新日時" DisplayMemberBinding="{Binding LastModified, StringFormat={}{0:yyyy/MM/dd HH:mm}}" Width="150"/>
                            <GridViewColumn Header="種類" DisplayMemberBinding="{Binding Type}" Width="120"/>
                            <GridViewColumn Header="サイズ" DisplayMemberBinding="{Binding Size}" Width="100"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Border Background="#0A0A0C"/>

        <Image Source="pack://application:,,,/Assets/kuro.png" Stretch="UniformToFill" Opacity="0.25"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TabControl Grid.Column="0" ItemsSource="{Binding LeftTabs}" SelectedIndex="0" 
                                Background="Transparent" BorderThickness="0" Margin="5"
                                ItemContainerStyle="{StaticResource FortressTabItemStyle}"
                                ItemTemplate="{StaticResource FortressTabHeaderTemplate}"
                                ContentTemplate="{StaticResource FortressTabContentTemplate}"
                                SelectionChanged="TabControl_SelectionChanged"/>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#3E3E42" Cursor="SizeWE"/>

                <TabControl Grid.Column="2" ItemsSource="{Binding RightTabs}" SelectedIndex="0" 
                                Background="Transparent" BorderThickness="0" Margin="5"
                                ItemContainerStyle="{StaticResource FortressTabItemStyle}"
                                ItemTemplate="{StaticResource FortressTabHeaderTemplate}"
                                ContentTemplate="{StaticResource FortressTabContentTemplate}"
                                SelectionChanged="TabControl_SelectionChanged"/>
            </Grid>
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#3E3E42" Cursor="SizeNS"/>

            <local:TerminalControl x:Name="BottomTerminal" Grid.Row="2" Opacity="0.85"/>
        </Grid>
    </Grid>
</Window>