<Window x:Class="Kuro_DockFortress.Views.PsPlusEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PS+ 魔導書エディタ" Height="550" Width="750"
        Background="#1E1E1E" WindowStartupLocation="CenterOwner"
        KeyUp="Window_KeyUp">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3E3E42" BorderThickness="0,0,0,1" Padding="10,0">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="SaveButton" Content="💾 保存 (Ctrl+S)" Width="110" Height="28" Margin="0,0,10,0"
                            Background="#0E639C" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                            Click="SaveButton_Click"/>

                    <Button x:Name="RunButton" Content="▶ 実行 (F5)" Width="100" Height="28"
                            Background="#388A34" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                            Click="RunButton_Click"/>
                </StackPanel>

                <TextBlock x:Name="StatusText" Foreground="#858585" VerticalAlignment="Center" HorizontalAlignment="Right"
                           FontFamily="Meiryo" FontSize="12" TextTrimming="CharacterEllipsis" Margin="20,0,0,0"/>
            </DockPanel>
        </Border>

        <TextBox x:Name="CodeEditor" Grid.Row="1"
                 Background="#1E1E1E" Foreground="#D4D4D4" CaretBrush="White"
                 BorderThickness="0" FontFamily="Consolas" FontSize="15"
                 AcceptsReturn="True" AcceptsTab="True" 
                 HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                 Padding="10" TextChanged="CodeEditor_TextChanged"/>
    </Grid>
</Window>