<Window x:Class="Kuro_DockHex.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kuro-DockHex" Height="311" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" 
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeave="Window_MouseLeave">

    <Grid MouseRightButtonUp="Grid_MouseRightButtonUp">
        <Polygon Points="75,0 525,0 600,150 525,300 75,300 0,150"
                 Fill="#1E1E1E" Stroke="#8E44AD" StrokeThickness="2" Opacity="0.95">
            <Polygon.Effect>
                <DropShadowEffect Color="#8E44AD" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
            </Polygon.Effect>
        </Polygon>

        <ScrollViewer Margin="70,30,65,30" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Memos}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#8E44AD" BorderThickness="1" Background="#11FFFFFF" 
                                CornerRadius="4" Margin="0,0,0,8" Padding="8">
                            <StackPanel>
                                <TextBlock Text="{Binding Text}" Foreground="#E0E0E0" TextWrapping="Wrap" 
                                           FontFamily="Meiryo" FontSize="12" Margin="0,0,0,5"/>

                                <TextBlock Text="{Binding TargetDate, StringFormat={}{0:yyyy/MM/dd HH:mm}}" 
                                           Foreground="#A0A0A0" FontFamily="Consolas" FontSize="10" 
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>