<Window x:Class="Kuro_DockGenesis.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KuroDock" SizeToContent="Height" Width="400" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" Topmost="True" ShowInTaskbar="False"
        Loaded="Window_Loaded"
        MouseLeave="Window_MouseLeave">

    <Grid x:Name="DockPanel" HorizontalAlignment="Right" Background="#AA222222" Grid.Row="1" AllowDrop="True"
          ContextMenuOpening="DockPanel_ContextMenuOpening"
          ContextMenuClosing="DockPanel_ContextMenuClosing">

        <Grid.RenderTransform>
            <TranslateTransform X="99"/>
        </Grid.RenderTransform>

        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <EventTrigger RoutedEvent="UIElement.PreviewMouseLeftButtonDown">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.2" >
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="DragEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.2" >
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="インデックスを追加" Click="AddIndex_Click"/>
                <Separator/>
                <MenuItem Header="終了" Click="Exit_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="0"/>
            <ColumnDefinition Width="Auto" MinWidth="0"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{x:Null}">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource KuroDockScrollBarStyle}"/>
            </ScrollViewer.Resources>
            <ItemsControl x:Name="SubBookmarksPanel" ItemsSource="{Binding CurrentSubBookmarks}" Background="{StaticResource KuroDockSubPanelBrush}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource KuroDockIconMenuButtonStyle}" Content="{Binding Name}" Click="Bookmark_Click" Opacity="0">
                            <Button.RenderTransform>
                                <TranslateTransform X="{Binding InitialOffsetX}" Y="{Binding InitialOffsetY}"/>
                            </Button.RenderTransform>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{x:Null}">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource KuroDockScrollBarStyle}"/>
            </ScrollViewer.Resources>
            <ItemsControl x:Name="BookmarksPanel" ItemsSource="{Binding CurrentBookmarks}" Background="{StaticResource KuroDockPanelBrush}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource KuroDockMenuButtonStyle}" Content="{Binding Name}" MouseEnter="Bookmark_MouseEnter" Click="Bookmark_Click" Opacity="0">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="名前を変更" Click="RenameBookmark_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Button.RenderTransform>
                                <TranslateTransform X="{Binding InitialOffsetX}" Y="{Binding InitialOffsetY}"/>
                            </Button.RenderTransform>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,10">

            <ItemsControl ItemsSource="{Binding IndexItems}" Padding="0,0,0,15">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Name}" Width="90" Height="30" Margin="0,2,0,0" HorizontalAlignment="Right" AllowDrop="True" Drop="IndexButton_Drop" MouseEnter="IndexButton_MouseEnter" Foreground="#DDDDDD" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Border" Background="#1AFFFFFF" BorderBrush="#44FFFFFF" BorderThickness="3,0,0,0" CornerRadius="10,0,0,10">
                                        <TextBlock x:Name="Text" Text="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0" FontWeight="SemiBold" FontSize="13"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource KuroDockAccentBrush}"/>
                                            <Setter TargetName="Text" Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Image Width="96" Height="96" HorizontalAlignment="Center" IsHitTestVisible="False">
                <Image.Source>
                    <BitmapImage UriSource="pack://application:,,,/Kuro-DockThrone.Core;component/Images/kuro.png" CacheOption="OnLoad"/>
                </Image.Source>
            </Image>
        </StackPanel>
    </Grid>
</Window>