<Window x:Class="KuroDockLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KuroDock" 
        Width="300"
        
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True" 
        Background="Transparent"
        Loaded="Window_Loaded"
        MouseLeave=""
        
        >

    <Grid MouseLeave="ClearPanel" Style="{StaticResource SlideAnimation}" Background="Transparent" AllowDrop="True">
        <Grid.RenderTransform>
            <TranslateTransform X="0"/>
        </Grid.RenderTransform>
        <Grid HorizontalAlignment="Right">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <Button Content="×" Width="90" Height="30" Grid.Row="0" Grid.Column="2" Click="CloseButton_Click" />
            <Border Grid.Row="1" Grid.Column="2" BorderBrush="Black" BorderThickness="1">
                <StackPanel x:Name="IndexFolderPanel">
                    <StackPanel.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#A0E0E6FA" Offset="0.0" />
                            <GradientStop Color="#A0C096EC" Offset="0.5" />
                            <GradientStop Color="#A08875D1" Offset="1.0" />
                        </LinearGradientBrush>
                    </StackPanel.Background>
                    <Border x:Name="FolderInputBorder" Height="30"/>
                    <StackPanel.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="フォルダインデックスを追加" Click="AddFolderIndex_Click"/>
                            <Separator/>
                            <MenuItem Header="閉じる"/>
                        </ContextMenu>
                    </StackPanel.ContextMenu>
                </StackPanel>
            </Border>
            <Border Grid.Row="2" Grid.Column="2" BorderBrush="Black" BorderThickness="1">
                <StackPanel x:Name="IndexFilePanel">
                    <StackPanel.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#A0E0E6FA" Offset="0.0" />
                            <GradientStop Color="#A0C096EC" Offset="0.5" />
                            <GradientStop Color="#A08875D1" Offset="1.0" />
                        </LinearGradientBrush>
                    </StackPanel.Background>
                    <Border x:Name="FileInputBorder" Height="30"/>
                    <StackPanel.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="ファイルインデックスを追加" Click="AddFileIndex_Click"/>
                            <Separator/>
                            <MenuItem Header="閉じる"/>
                        </ContextMenu>
                    </StackPanel.ContextMenu>
                </StackPanel>
            </Border>
            <StackPanel x:Name="FolderMiddlePanel" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Background="Gray"/>
            <StackPanel x:Name="FileMiddlePanel" Grid.Row="2" Grid.Column="1" Background="Gray"/>
            <StackPanel x:Name="FolderPulldown" Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Background="DarkGray"/>
        </Grid>
    </Grid>
</Window>