<Window x:Class="Kuro_DockLauncher2.Views.RenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="別名の設定" Height="160" Width="300"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterScreen"
        Background="#222222" Topmost="True">

    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="新しい名前（空にすると元に戻りますわ）:" Foreground="White" Margin="0,0,0,10"/>
            <TextBox x:Name="NameTextBox" FontSize="16" Padding="2" Margin="0,0,0,15" Background="#333" Foreground="White" BorderBrush="#555"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="80" Height="25" Margin="0,0,10,0" Click="OK_Click" Background="#444" Foreground="White" BorderThickness="0"/>
                <Button Content="キャンセル" Width="80" Height="25" Click="Cancel_Click" Background="#444" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>